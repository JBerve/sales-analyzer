#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Check branch naming convention
branch=$(git rev-parse --abbrev-ref HEAD)
valid_pattern="^(feature|fix|hotfix|release|docs|refactor|test|chore)\/[a-z0-9-]+$"

if [[ "$branch" != "main" && "$branch" != "develop" && ! "$branch" =~ $valid_pattern ]]; then
  echo "❌ Branch name '$branch' does not follow naming convention!"
  echo "Expected format: type/description"
  echo "Valid types: feature, fix, hotfix, release, docs, refactor, test, chore"
  echo "Example: feature/user-authentication"
  exit 1
fi

echo "✅ Branch name follows convention"
